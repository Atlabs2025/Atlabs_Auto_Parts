<odoo>
    <record id="view_product_template_form_inherit_auto_parts" model="ir.ui.view">
        <field name="name">product.template.form.inherit.auto.parts</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="default_code" position="attributes">
                <attribute name="string">Part Number</attribute>
            </field>

            <xpath expr="//page[@name='inventory']" position="after">
                <page string="Auto Part Details">
                    <group>
                        <field name="group_id"/>
                        <field name="sub_group_id"/>
                    </group>
                    <notebook>

                        <!--                        <page string="Used in Vehicles">-->
                        <page string="Used in Vehicles">
                            <field name="used_in_vehicle_ids" mode="list">
                                <list editable="bottom">
                                    <field name="license_plate"/>
                                    <field name="model_id"/>
                                    <field name="brand_id"/>
                                    <field name="fuel_type"/>
                                    <field name="transmission"/>
                                    <field name="odometer"/>
                                    <field name="color"/>
                                </list>
                            </field>
                        </page>

                        <page string="OE Numbers">
                            <group>
                                <field name="oe_number_line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="manufacturer_id"/>
                                        <field name="oe_number_id" widget="many2many_tags"/>
                                        <field name="description"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Characteristics">
                            <field name="characteristic_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="key"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>

                        <page string="Technical Data">
                            <field name="technical_data_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="caption"/>
                                    <field name="technical_link" widget="url"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </page>
            </xpath>
        </field>
    </record>
    <record id="view_product_template_search_custom" model="ir.ui.view">
        <field name="name">product.template.search</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="oe_number_names" string="OE Number"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_tree_inherit_stock_value" model="ir.ui.view">
        <field name="name">product.product.tree.stock.value</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='qty_available']" position="after">
                <field name="stock_value" widget="monetary" sum="Total Value"/>
            </xpath>
            <!-- Remove the original category field -->
            <xpath expr="//field[@name='categ_id']" position="replace"/>

             <!-- Move category before sale price -->
            <xpath expr="//field[@name='list_price']" position="before" optional="show">
                <field name="categ_id"/>
            </xpath>



        </field>
    </record>





</odoo>