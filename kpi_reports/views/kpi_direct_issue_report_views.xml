<odoo>

    <!-- TREE VIEW -->
    <record id="view_kpi_direct_issue_report_tree" model="ir.ui.view">
        <field name="name">kpi.direct.issue.report.tree</field>
        <field name="model">kpi.direct.issue.report</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="car_id"/>
                <field name="vehicle_name"/>
                <field name="vin_sn"/>
                <field name="issue_date"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="product_id"/>
                <field name="issued_qty"/>
                <field name="unit_price"/>
                <field name="total_value"/>
            </list>
        </field>
    </record>


    <!-- SEARCH VIEW -->
    <record id="view_kpi_direct_issue_report_search" model="ir.ui.view">
        <field name="name">kpi.direct.issue.report.search</field>
        <field name="model">kpi.direct.issue.report</field>
        <field name="arch" type="xml">
            <search>

                <field name="car_id"/>
                <field name="vin_sn"/>
                <field name="product_id"/>
                <field name="department_id"/>
                <field name="employee_id"/>

                <filter name="today"
                        string="Today"
                        domain="[('issue_date','=',context_today())]"/>

<!--                <group expand="0" string="Group By">-->

<!--                    <filter string="Department"-->
<!--                            context="{'group_by':'department_id'}"/>-->

<!--                    <filter string="Product"-->
<!--                            context="{'group_by':'product_id'}"/>-->

<!--                    <filter string="Car"-->
<!--                            context="{'group_by':'car_id'}"/>-->

<!--                    <filter string="Date"-->
<!--                            context="{'group_by':'issue_date'}"/>-->

<!--                </group>-->

            </search>
        </field>
    </record>


    <!-- PIVOT VIEW -->
    <record id="view_kpi_direct_issue_report_pivot" model="ir.ui.view">
        <field name="name">kpi.direct.issue.report.pivot</field>
        <field name="model">kpi.direct.issue.report</field>
        <field name="arch" type="xml">
            <pivot>

                <field name="department_id" type="row"/>
                <field name="product_id" type="row"/>

                <field name="issued_qty" type="measure"/>
                <field name="total_value" type="measure"/>

            </pivot>
        </field>
    </record>


    <!-- ACTION -->
    <record id="action_kpi_direct_issue_report" model="ir.actions.act_window">
        <field name="name">Direct Issue Report</field>
        <field name="res_model">kpi.direct.issue.report</field>
        <field name="view_mode">list,pivot</field>
<!--        <field name="search_view_id"-->
<!--               ref="view_kpi_direct_issue_report_search"/>-->
    </record>


    <!-- MENU -->
    <menuitem
        id="menu_kpi_direct_issue_report"
        name="Direct Issue Report"
        parent="kpi_reports.menu_kpi_root"
        action="action_kpi_direct_issue_report"
        sequence="20"/>

</odoo>